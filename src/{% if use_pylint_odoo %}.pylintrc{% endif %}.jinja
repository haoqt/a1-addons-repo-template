{#-
  pylint-odoo config for Odoo {{ odoo_version }} ({{ odoo_edition }}).
  Regenerate with `copier update` — do not hand-edit unless you also
  update the template.
-#}
{%- set is_modern = odoo_version >= 14.0 -%}
{%- set plugin_name = "pylint_odoo" -%}
[MASTER]
load-plugins={{ plugin_name }}
score=no
# Keep pylint fast: analyse in parallel and skip generated / vendored code.
jobs=4
ignore=setup,migrations,tests/data,static/lib,__pycache__

[MESSAGES CONTROL]
# Disable noise we accept in Odoo modules; enable Odoo-specific checks by
# category so new pylint-odoo releases can add rules without breaking us.
disable=all

enable=
    # Odoo-specific checks (pylint-odoo)
    odoolint,
{%- if is_modern %}
    # pylint 2.x/3.x — bug-catching checks (formatting handled by black).
    # E1101 (no-member) is DELIBERATELY OMITTED: Odoo composes model
    # classes at runtime, so pylint cannot statically resolve inherited
    # methods and produces frequent false positives.
    C0102,C0112,C0113,C0202,C0203,C0204,C0303,C0304,C0321,
    E0001,E0011,E0012,E0100,E0101,E0102,E0103,E0104,E0105,E0106,E0107,
    E0108,E0202,E0203,E0211,E0213,E0236,E0237,E0238,E0239,E0240,E0241,
    E0301,E0302,E0601,E0602,E0603,E0604,E0701,E0702,
    E0710,E0711,E0712,E1003,E1102,E1111,E1120,E1121,E1123,E1124,
    E1125,E1126,E1127,E1129,E1130,E1131,E1132,E1200,E1201,E1205,E1206,
    E1300,E1301,E1302,E1303,E1304,E1305,E1306,E1310,E1700,E1701,
    W0101,W0102,W0104,W0105,W0106,W0107,W0108,W0109,W0120,W0122,
    W0124,W0150,W0199,W0221,W0222,W0233,W0301,W0311,W0401,W0404,
    W0410,W0601,W0602,W0604,W0611,W0612,W0622,W0702,W0705,W0711,
    W1201,W1300,W1301,W1302,W1303,W1304,W1305,W1306,W1307,
{%- else %}
    # pylint 1.x (Odoo 12 and older) — narrower, safer set
    C0102,C0112,C0113,C0202,C0203,C0204,
    E0001,E0011,E0012,E0100,E0101,E0102,E0103,E0104,E0105,E0106,E0107,
    W0101,W0102,W0104,W0105,W0106,W0107,W0108,W0109,W0110,W0120,W0122,
    W0124,W0150,W0199,W0221,W0222,W0233,W0301,W0311,W0312,W0401,W0404,
    W0410,W0601,W0602,W0604,W0611,W0612,W0622,W0623,W0702,W0705,W0711,
{%- endif %}

[ODOOLINT]
readme-template-url=https://github.com/{{ org_slug }}/{{ repo_slug }}/blob/{{ target_branch }}/README.md
manifest-required-authors={{ org_name }}
manifest-required-keys=license
manifest-deprecated-keys=description,active
license-allowed=OPL-1,LGPL-3,AGPL-3,Other proprietary
valid-odoo-versions={{ odoo_version }}

[REPORTS]
msg-template={C}:{line:3d},{column}:{obj}: {msg} [{msg_id}({symbol})]
reports=no

[FORMAT]
max-line-length=88
