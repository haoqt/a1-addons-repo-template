{%- set py_version = {
    10.0: "2.7",
    11.0: "3.5",
    12.0: "3.6",
    13.0: "3.6",
    14.0: "3.6",
    15.0: "3.8",
    16.0: "3.10",
    17.0: "3.10",
    18.0: "3.10",
    19.0: "3.12",
}[odoo_version] -%}
# Pre-commit config generated by odoo-project-github-template.
# Do not edit manually; re-run `copier update` to change tooling versions.
exclude: |
  (?x)
  # NOT INSTALLABLE ADDONS
  # END NOT INSTALLABLE ADDONS
  # Files that must not be modified by hooks
  /static/(src/)?lib/|
  /static/description/index\.html|
  \.pot?$
default_language_version:
  python: python{{ py_version }}
repos:
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v4.6.0
    hooks:
      - id: check-added-large-files
      - id: check-case-conflict
      - id: check-executables-have-shebangs
      - id: check-merge-conflict
      - id: check-symlinks
      - id: check-yaml
      - id: check-xml
      - id: end-of-file-fixer
      - id: mixed-line-ending
        args: ["--fix=lf"]
      - id: trailing-whitespace
  - repo: https://github.com/psf/black
    rev: 24.4.2
    hooks:
      - id: black
        language_version: python{{ py_version }}
  - repo: https://github.com/PyCQA/isort
    rev: 5.13.2
    hooks:
      - id: isort
        name: isort (except __init__.py)
        exclude: /__init__\.py$
  - repo: https://github.com/asottile/pyupgrade
    rev: v3.16.0
    hooks:
      - id: pyupgrade
        args: ["--py{{ py_version | replace('.', '') }}-plus", "--keep-percent-format"]
  - repo: https://github.com/PyCQA/flake8
    rev: 7.1.1
    hooks:
      - id: flake8
        additional_dependencies:
          - flake8-bugbear==24.4.26
  - repo: https://github.com/pre-commit/mirrors-prettier
    rev: v3.1.0
    hooks:
      - id: prettier
        files: \.(css|htm|html|js|json|jsx|less|md|scss|toml|ts|yaml|yml)$
  # OCA odoo-module structural checks (blocking).
  - repo: https://github.com/OCA/odoo-pre-commit-hooks
    rev: v0.0.33
    hooks:
      - id: oca-checks-odoo-module
      - id: oca-checks-po
{%- if use_pylint_odoo %}
  - repo: local
    hooks:
      - id: pylint-odoo
        name: pylint-odoo
        entry: pylint
        args: ["--rcfile=.pylintrc"]
        language: python
        types: [python]
        # Only run against files inside a module (skip repo-level scripts).
        files: ^[^/]+/[^/]+.*\.py$
        additional_dependencies:
          - "pylint-odoo=={{ pylint_odoo_version }}"
{%- endif %}
