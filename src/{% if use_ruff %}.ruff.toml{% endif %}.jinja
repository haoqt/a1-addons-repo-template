{%- set py_target = {
    14.0: "py36",
    15.0: "py38",
    16.0: "py310",
    17.0: "py310",
    18.0: "py310",
    19.0: "py312",
}[odoo_version] -%}
# Generated by a1-addons-repo-template; edit `additional_ruff_rules`
# in .copier-answers.yml and re-run `copier update` to change lint rules.
target-version = "{{ py_target }}"
line-length = 88
fix = true

exclude = [
    "setup/*",
    "*/migrations/*",
    "*/tests/data/*",
    "*/static/lib/*",
]

[lint]
select = [
    "E",   # pycodestyle errors
    "F",   # pyflakes
    "W",   # pycodestyle warnings
    "I",   # isort
    "UP",  # pyupgrade
    "B",   # bugbear
    "C4",  # comprehensions
    "SIM", # simplify
{%- for rule in additional_ruff_rules %}
    "{{ rule }}",
{%- endfor %}
]
ignore = [
    "E501",  # handled by ruff-format
]

[lint.per-file-ignores]
"__init__.py" = ["F401"]
"__manifest__.py" = ["B018"]

[lint.isort]
known-first-party = ["odoo"]

[format]
quote-style = "double"
indent-style = "space"
